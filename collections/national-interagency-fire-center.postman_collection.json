  "info": {
    "_postman_id": "5320cc75-7cff-4ee9-bd35-5fa41d9f3d97",
    "name": "NIFC ArcGIS REST Services API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The National Interagency Fire Center hosts an ArcGIS REST Services Directory exposing FeatureServer services that provide authoritative geospatial data on wildfire incidents, fire perimeters, dispatch boundaries, fuel treatments, weather stations, and related fire management resources. This specification documents the common ArcGIS REST conventions used by NIFC's hosted services.\n\nContact Support:\n Name: National Interagency Fire Center",
      "type": "text/plain"
    }
  }
